{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["AUTO_UPDATE_BASE_URL", "MARKETING_ORIGIN", "NEXT_PUBLIC_PRODUCT_WEB_URL"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "out/**",
        "dist/**",
        "dist-electron/**",
        ".bundle/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "app/**",
        "tests/**",
        "bunfig.toml",
        "tsconfig*.json"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^test:unit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "lib/**",
        "tests/**",
        "bunfig.toml",
        "tsconfig*.json"
      ],
      "outputs": []
    },
    "test:integration": {
      "inputs": ["$TURBO_DEFAULT$", "src/**", "tests/**", "bunfig.toml", "tsconfig*.json"],
      "outputs": []
    },
    "test:e2e": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "app/**",
        "src/**",
        "tests/**",
        "bunfig.toml",
        "tsconfig*.json"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "desktop#build": {
      "dependsOn": ["web#build"]
    }
  }
}
