# Public cross-app routing
MARKETING_ORIGIN=https://turborepo-scaffold.vercel.app
NEXT_PUBLIC_PRODUCT_WEB_URL=https://turborepo-scaffold-web.vercel.app

# Desktop auto-update feed URL consumed by packaged apps.
AUTO_UPDATE_BASE_URL=https://downloads.example.com/myapp

# Optional Forge publisher settings for Cloudflare R2 / S3-compatible storage.
AUTO_UPDATE_S3_BUCKET=your-r2-bucket
AUTO_UPDATE_S3_REGION=auto
AUTO_UPDATE_S3_FOLDER=myapp
AUTO_UPDATE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AUTO_UPDATE_S3_ACCESS_KEY_ID=<r2-access-key-id>
AUTO_UPDATE_S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
AUTO_UPDATE_S3_FORCE_PATH_STYLE=true
AUTO_UPDATE_S3_OMIT_ACL=true
AUTO_UPDATE_KEEP_RELEASES=2

# Optional macOS release signing/notarization for public distribution.
APPLE_SIGNING_IDENTITY=Developer ID Application: Example, Inc. (TEAMID1234)
APPLE_ID=developer@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=TEAMID1234
APPLE_CERTIFICATE_P12_BASE64=<base64-encoded-developer-id-application-p12>
APPLE_CERTIFICATE_PASSWORD=<p12-password>
