AUTO_UPDATE_BASE_URL=https://downloads.example.com/myapp

# R2 / S3 publish variables (only needed for `bun run publish`)
AUTO_UPDATE_S3_BUCKET=your-r2-bucket
AUTO_UPDATE_S3_REGION=auto
AUTO_UPDATE_S3_FOLDER=myapp
AUTO_UPDATE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AUTO_UPDATE_S3_ACCESS_KEY_ID=<r2-access-key-id>
AUTO_UPDATE_S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
AUTO_UPDATE_S3_FORCE_PATH_STYLE=true
AUTO_UPDATE_S3_OMIT_ACL=true
