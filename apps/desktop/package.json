{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for the shared Next.js application",
  "author": "Next Electron Turborepo",
  "type": "module",
  "main": ".electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "package": "node ./scripts/forge-with-env.mjs package",
    "make": "node ./scripts/forge-with-env.mjs make",
    "publish": "node ./scripts/forge-with-env.mjs publish",
    "build": "bun run make",
    "lint": "oxlint src scripts electron.vite.config.ts --deny-warnings",
    "format": "oxfmt --write .",
    "check-types": "tsc --noEmit -p tsconfig.node.json",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test --preload ../../tests/setup.browser.ts src/main src/shared --pass-with-no-tests",
    "test:integration": "bun run ../../scripts/run-isolated-tests.mjs tests/integration"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/core": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/publisher-s3": "^7.11.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.5.0",
    "electron": "^41.0.3",
    "electron-vite": "^5.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  }
}
