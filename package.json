{
  "name": "next-electron-turborepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build": "turbo run build --filter=web --filter=desktop",
    "dev": "turbo run dev --filter=web --filter=desktop",
    "desktop": "turbo run dev --filter=web --filter=desktop",
    "docs": "turbo run dev --filter=docs",
    "web": "turbo run dev --filter=web",
    "lint": "oxlint . --deny-warnings",
    "format": "oxfmt --write .",
    "format:check": "bunx oxfmt --check .",
    "check-types": "turbo run check-types",
    "test": "bun run test:unit && bun run test:integration && bun run test:e2e",
    "test:unit": "turbo run test:unit && bun test scripts --pass-with-no-tests",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "check": "bun run lint && bun run format:check && bun run check-types && bun run test",
    "ci": "bun run check && bun run build"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "bun-types": "^1.3.11",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.8",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.4",
  "trustedDependencies": [
    "electron"
  ]
}
