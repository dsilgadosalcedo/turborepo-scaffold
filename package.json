{
  "name": "next-electron-turborepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build": "turbo run build --filter=web --filter=desktop",
    "dev": "turbo run dev --filter=web --filter=desktop",
    "desktop": "turbo run dev --filter=web --filter=desktop",
    "docs": "turbo run dev --filter=docs",
    "web": "turbo run dev --filter=web",
    "lint": "oxlint . --deny-warnings",
    "format": "oxfmt --write .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.4",
  "trustedDependencies": [
    "electron"
  ]
}
